@model UserManagement.Models.UserModel

@{
    Layout = null;
    var aadhaar = ViewBag.AadhaarDoc as UserManagement.Models.UserDocumentModel;
    var pan = ViewBag.PanDoc as UserManagement.Models.UserDocumentModel;
    var other = ViewBag.OtherDoc as UserManagement.Models.UserDocumentModel;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Details - Admin Control</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        body {
            background: linear-gradient(135deg, #0b132b, #1c2541);
            min-height: 100vh;
            padding: 40px 0;
            font-family: 'Segoe UI', sans-serif;
        }

        .container-box {
            width: 90%;
            max-width: 950px;
            margin: 0 auto;
        }

        .page-heading {
            color: white;
            font-size: 32px;
            font-weight: 800;
            text-transform: uppercase;
            margin-bottom: 25px;
            text-shadow: 0 4px 15px rgba(0,0,0,0.4);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .main-card {
            background: #ffffff;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);
        }

        .details-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px 40px;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 30px;
            margin-bottom: 30px;
        }

        .details-item {
            display: flex;
            flex-direction: column;
        }

        .details-label {
            font-size: 11px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .details-value {
            font-size: 16px;
            font-weight: 600;
            color: #0f172a;
        }

        .section-title {
            font-size: 20px;
            font-weight: 700;
            color: #1e3a8a;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .doc-card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 35px;
        }

        .doc-card {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 160px;
            transition: all 0.3s ease;
        }

        .doc-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.05);
            border-color: #cbd5e1;
        }

        .doc-title {
            font-size: 15px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 12px;
        }

        .doc-status-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .btn-action {
            height: 48px;
            border-radius: 10px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.2s ease;
        }

        .btn-action:hover {
            transform: translateY(-1px);
        }

        @@media (max-width: 768px) {
            .details-grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }
            .main-card {
                padding: 25px;
            }
            .page-heading {
                font-size: 26px;
            }
        }
    </style>
</head>
<body>

    <div class="container-box">

        <!-- HEADER -->
        <h1 class="page-heading">
            <i class="bi bi-person-badge-fill"></i> User Profile Details
        </h1>

        <!-- DETAILS CARD -->
        <div class="main-card">
            
            <!-- GENERAL INFO SECTION -->
            <h3 class="section-title">
                <i class="bi bi-person-fill"></i> Account Information
            </h3>

            <div class="details-grid">
                <div class="details-item">
                    <span class="details-label">User ID</span>
                    <span class="details-value">#@Model.UserId</span>
                </div>

                <div class="details-item">
                    <span class="details-label">Account Status</span>
                    <span class="details-value">
                        <span class="badge bg-success px-2.5 py-1.5" style="border-radius: 6px; font-size:13px;">
                            <i class="bi bi-check-circle-fill me-1"></i> Active
                        </span>
                    </span>
                </div>

                <div class="details-item">
                    <span class="details-label">Full Name</span>
                    <span class="details-value">@Model.FullName</span>
                </div>

                <div class="details-item">
                    <span class="details-label">Username</span>
                    <span class="details-value">@Model.Username</span>
                </div>

                <div class="details-item">
                    <span class="details-label">Email Address</span>
                    <span class="details-value">@Model.EmailId</span>
                </div>

                <div class="details-item">
                    <span class="details-label">Mobile Number</span>
                    <span class="details-value">@Model.MobileNo</span>
                </div>

                <div class="details-item">
                    <span class="details-label">User Role</span>
                    <span class="details-value">@Model.RoleName</span>
                </div>

                <div class="details-item">
                    <span class="details-label">Registration Date</span>
                    <span class="details-value">@Model.CreatedDate.ToString("dd MMMM yyyy, hh:mm tt")</span>
                </div>
            </div>

            <!-- DOCUMENTS SECTION -->
            <h3 class="section-title">
                <i class="bi bi-folder-fill"></i> Uploaded Documents
            </h3>

            <div class="doc-card-grid">
                <!-- Aadhaar Card -->
                <div class="doc-card">
                    <div>
                        <div class="doc-title"><span class="me-1">🪪</span> Aadhaar Card</div>
                        <div class="doc-status-row">
                            <span class="text-secondary" style="font-size:13px;">Status:</span>
                            @if (aadhaar != null)
                            {
                                @if (aadhaar.Status == "Approved")
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1" style="border-radius: 6px;"><i class="bi bi-check-circle-fill"></i> Approved</span>
                                }
                                else if (aadhaar.Status == "Rejected")
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1" style="border-radius: 6px;"><i class="bi bi-x-circle-fill"></i> Rejected</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1" style="border-radius: 6px;"><i class="bi bi-hourglass-split"></i> Pending</span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1" style="border-radius: 6px;"><i class="bi bi-file-earmark-x"></i> Missing</span>
                            }
                        </div>
                    </div>
                    @if (aadhaar != null)
                    {
                        <a href="/uploads/@aadhaar.FilePath" target="_blank" class="btn btn-sm btn-primary w-100 d-inline-flex align-items-center justify-content-center gap-1.5" style="border-radius: 8px;">
                            <i class="bi bi-eye-fill"></i> View Aadhaar
                        </a>
                    }
                </div>

                <!-- PAN Card -->
                <div class="doc-card">
                    <div>
                        <div class="doc-title"><span class="me-1">💳</span> PAN Card</div>
                        <div class="doc-status-row">
                            <span class="text-secondary" style="font-size:13px;">Status:</span>
                            @if (pan != null)
                            {
                                @if (pan.Status == "Approved")
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1" style="border-radius: 6px;"><i class="bi bi-check-circle-fill"></i> Approved</span>
                                }
                                else if (pan.Status == "Rejected")
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1" style="border-radius: 6px;"><i class="bi bi-x-circle-fill"></i> Rejected</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1" style="border-radius: 6px;"><i class="bi bi-hourglass-split"></i> Pending</span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1" style="border-radius: 6px;"><i class="bi bi-file-earmark-x"></i> Missing</span>
                            }
                        </div>
                    </div>
                    @if (pan != null)
                    {
                        <a href="/uploads/@pan.FilePath" target="_blank" class="btn btn-sm btn-primary w-100 d-inline-flex align-items-center justify-content-center gap-1.5" style="border-radius: 8px;">
                            <i class="bi bi-eye-fill"></i> View PAN Card
                        </a>
                    }
                </div>

                <!-- Other Document -->
                <div class="doc-card">
                    <div>
                        <div class="doc-title"><span class="me-1">📄</span> Other Document</div>
                        <div class="doc-status-row">
                            <span class="text-secondary" style="font-size:13px;">Status:</span>
                            @if (other != null)
                            {
                                @if (other.Status == "Approved")
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1" style="border-radius: 6px;"><i class="bi bi-check-circle-fill"></i> Approved</span>
                                }
                                else if (other.Status == "Rejected")
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1" style="border-radius: 6px;"><i class="bi bi-x-circle-fill"></i> Rejected</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1" style="border-radius: 6px;"><i class="bi bi-hourglass-split"></i> Pending</span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1" style="border-radius: 6px;"><i class="bi bi-file-earmark-x"></i> Not Uploaded</span>
                            }
                        </div>
                    </div>
                    @if (other != null)
                    {
                        <a href="/uploads/@other.FilePath" target="_blank" class="btn btn-sm btn-primary w-100 d-inline-flex align-items-center justify-content-center gap-1.5" style="border-radius: 8px;">
                            <i class="bi bi-eye-fill"></i> View Other Doc
                        </a>
                    }
                </div>
            </div>

            <!-- ACTION FOOTER BUTTONS -->
            <div class="row g-3 border-top pt-4">
                <div class="col-md-4">
                    <a asp-action="UserList" class="btn btn-secondary btn-action w-100">
                        <i class="bi bi-arrow-left"></i> Back to User List
                    </a>
                </div>
                <div class="col-md-4">
                    <a asp-action="EditUser" asp-route-id="@Model.UserId" class="btn btn-warning btn-action w-100">
                        <i class="bi bi-pencil-square"></i> Edit User Info
                    </a>
                </div>
                <div class="col-md-4">
                    <button type="button" class="btn btn-danger btn-action w-100" data-bs-toggle="modal" data-bs-target="#deleteUserModal">
                        <i class="bi bi-trash3-fill"></i> Delete User Account
                    </button>
                </div>
            </div>

        </div>

    </div>

    <!-- DELETE CONFIRMATION MODAL -->
    <div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 18px; border: none; box-shadow: 0 15px 35px rgba(0,0,0,0.35);">
                <div class="modal-header bg-danger text-white border-0 py-3 px-4" style="border-top-left-radius: 18px; border-top-right-radius: 18px;">
                    <h5 class="modal-title fw-bold" id="deleteModalLabel">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Delete User Account
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body px-4 py-3 text-secondary" style="font-size: 15px; line-height: 1.6;">
                    <p class="text-dark fw-bold">Are you sure you want to permanently delete this user account?</p>
                    <p class="mb-0">
                        This will delete the user account for <strong>@Model.FullName (@Model.Username)</strong> and erase all associated documents.
                    </p>
                </div>
                <div class="modal-footer border-0 px-4 pb-4 pt-2 gap-2">
                    <button type="button" class="btn btn-light px-3 py-2 fw-semibold" data-bs-dismiss="modal" style="border-radius: 10px; font-size: 14px;">Cancel</button>
                    <a href="/Home/DeleteUser/@Model.UserId" class="btn btn-danger px-4 py-2 fw-semibold" style="border-radius: 10px; font-size: 14px;">
                        Yes, Delete Permanently
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
