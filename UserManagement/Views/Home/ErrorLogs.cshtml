@model UserManagement.Models.ErrorLogsListViewModel

@{
    Layout = null;
    var currentRole = Context.Session.GetString("UserRole") ?? "";
    bool isSuperAdmin = currentRole == "3"; // Role "3" is SuperAdmin
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Enterprise Error Logs - Admin Control</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            background: linear-gradient(135deg, #0b132b, #1c2541);
            min-height: 100vh;
            color: #f8fafc;
            font-family: 'Segoe UI', sans-serif;
            padding: 30px 0;
        }

        .dashboard-container {
            width: 95%;
            max-width: 1400px;
            margin: 0 auto;
        }

        .card-panel {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
            margin-bottom: 30px;
        }

        .header-panel {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding-bottom: 20px;
            margin-bottom: 25px;
        }

        .page-title {
            font-size: 28px;
            font-weight: 800;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 12px;
            background: linear-gradient(135deg, #3b82f6, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Stats Cards */
        .stat-card {
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-3px);
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(59, 130, 246, 0.3);
        }

        .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: white;
        }

        .bg-total { background: linear-gradient(135deg, #475569, #64748b); }
        .bg-today { background: linear-gradient(135deg, #0284c7, #0ea5e9); }
        .bg-critical { background: linear-gradient(135deg, #dc2626, #ef4444); }
        .bg-resolved { background: linear-gradient(135deg, #16a34a, #22c55e); }

        .stat-details h3 {
            font-size: 14px;
            color: #94a3b8;
            margin: 0;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-details p {
            font-size: 24px;
            font-weight: 800;
            margin: 0;
            color: white;
        }

        /* Filter Controls */
        .filter-panel {
            background: rgba(0, 0, 0, 0.15);
            border-radius: 14px;
            padding: 20px;
            margin-bottom: 25px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .form-control, .form-select {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: white;
            border-radius: 8px;
        }

        .form-control:focus, .form-select:focus {
            background: rgba(15, 23, 42, 0.8);
            color: white;
            border-color: #3b82f6;
            box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.25);
        }

        .form-label {
            color: #94a3b8;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 6px;
        }

        /* Table custom design */
        .table-responsive {
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .table {
            margin-bottom: 0;
            color: #e2e8f0;
            background: rgba(15, 23, 42, 0.3);
        }

        .table th {
            background: #0f172a !important;
            color: #94a3b8;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 0.5px;
            padding: 15px 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .table td {
            padding: 14px 12px;
            vertical-align: middle;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            background: transparent !important;
            color: #cbd5e1;
        }

        .table tbody tr {
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .table tbody tr:hover {
            background: rgba(255, 255, 255, 0.04) !important;
        }

        .badge-severity {
            font-size: 11px;
            font-weight: 700;
            padding: 5px 10px;
            border-radius: 20px;
            text-transform: uppercase;
        }

        .severity-critical { background-color: rgba(239, 68, 68, 0.15); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.3); }
        .severity-high { background-color: rgba(245, 158, 11, 0.15); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.3); }
        .severity-medium { background-color: rgba(59, 130, 246, 0.15); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.3); }
        .severity-low { background-color: rgba(71, 85, 105, 0.2); color: #94a3b8; border: 1px solid rgba(71, 85, 105, 0.4); }

        .badge-status {
            font-size: 11px;
            font-weight: 700;
            padding: 4px 8px;
            border-radius: 6px;
        }
        .status-resolved { background-color: rgba(34, 197, 94, 0.15); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.3); }
        .status-unresolved { background-color: rgba(239, 68, 68, 0.15); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.3); }

        /* Modals */
        .modal-content {
            background: #0f172a;
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: #f8fafc;
            border-radius: 18px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.6);
        }

        .modal-header {
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding: 20px 24px;
        }

        .modal-body {
            padding: 24px;
            max-height: 70vh;
            overflow-y: auto;
        }

        .modal-footer {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding: 15px 24px;
        }

        .detail-group {
            margin-bottom: 18px;
        }

        .detail-label {
            font-size: 12px;
            text-transform: uppercase;
            color: #94a3b8;
            font-weight: 700;
            margin-bottom: 4px;
            letter-spacing: 0.5px;
        }

        .detail-value {
            font-size: 15px;
            color: #e2e8f0;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 8px 12px;
            border-radius: 6px;
            word-break: break-all;
        }

        .stack-trace-box {
            font-family: monospace;
            font-size: 12.5px;
            background: rgba(0, 0, 0, 0.4) !important;
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 15px;
            border-radius: 8px;
            color: #f1f5f9;
            max-height: 250px;
            overflow-y: auto;
            white-space: pre-wrap;
            word-break: break-all;
        }

        .btn-action-modal {
            font-size: 13.5px;
            font-weight: 600;
            padding: 8px 16px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s ease;
        }

        /* Pagination custom styling */
        .pagination {
            margin-top: 20px;
            justify-content: center;
            gap: 5px;
        }

        .page-link {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #cbd5e1;
            border-radius: 6px !important;
            transition: all 0.2s ease;
        }

        .page-link:hover {
            background: rgba(255, 255, 255, 0.15);
            color: white;
            border-color: rgba(255, 255, 255, 0.2);
        }

        .page-item.active .page-link {
            background: linear-gradient(135deg, #2563eb, #3b82f6);
            border-color: transparent;
            color: white;
            font-weight: bold;
        }

        .page-item.disabled .page-link {
            background: rgba(255, 255, 255, 0.02);
            border-color: rgba(255, 255, 255, 0.05);
            color: #64748b;
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        
        <!-- Header -->
        <div class="card-panel">
            <div class="header-panel">
                <h1 class="page-title">
                    <i class="bi bi-shield-fill-exclamation text-primary"></i>
                    Enterprise Error Logs Dashboard
                </h1>
                <div class="d-flex gap-2">
                    <a href="/Home/Dashboard" class="btn btn-outline-light btn-sm rounded-pill px-3">
                        <i class="bi bi-arrow-left"></i> Back to Dashboard
                    </a>
                    @if (isSuperAdmin)
                    {
                        <form asp-action="ClearAllErrorLogs" method="post" onsubmit="return confirm('Are you absolutely sure you want to delete ALL error logs? This action is irreversible.');" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm rounded-pill px-3">
                                <i class="bi bi-trash3-fill"></i> Clear All Logs
                            </button>
                        </form>
                    }
                </div>
            </div>

            <!-- Toast / Alerts -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show bg-success bg-opacity-25 border-success text-white rounded-3 mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show bg-danger bg-opacity-25 border-danger text-white rounded-3 mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Statistics Grid -->
            <div class="row g-4 mb-4">
                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="stat-card">
                        <div class="stat-icon bg-total">
                            <i class="bi bi-database"></i>
                        </div>
                        <div class="stat-details">
                            <h3>Total Logs</h3>
                            <p>@Model.TotalErrorsCount</p>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="stat-card">
                        <div class="stat-icon bg-today">
                            <i class="bi bi-activity"></i>
                        </div>
                        <div class="stat-details">
                            <h3>Today's Count</h3>
                            <p>@Model.TodaysErrorsCount</p>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="stat-card">
                        <div class="stat-icon bg-critical">
                            <i class="bi bi-fire"></i>
                        </div>
                        <div class="stat-details">
                            <h3>Critical Unresolved</h3>
                            <p>@Model.CriticalErrorsCount</p>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="stat-card">
                        <div class="stat-icon bg-resolved">
                            <i class="bi bi-check2-circle"></i>
                        </div>
                        <div class="stat-details">
                            <h3>Resolved Logs</h3>
                            <p>@Model.ResolvedErrorsCount</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Filters & Search -->
            <div class="filter-panel">
                <form id="filterForm" method="get" action="/Home/ErrorLogs">
                    <div class="row g-3">
                        <div class="col-12 col-md-3">
                            <label class="form-label">Search</label>
                            <input type="text" name="search" class="form-control" placeholder="Search msg, action, user..." value="@Model.Search" />
                        </div>
                        <div class="col-6 col-md-2">
                            <label class="form-label">Severity</label>
                            <select name="severity" class="form-select">
                                <option value="">All Severities</option>
                                @foreach (var sev in Model.Severities)
                                {
                                    <!---->
                                    <option value="@sev" selected="@(sev == Model.Severity ? "selected" : null)">@sev</option>
                                }
                            </select>
                        </div>
                        <div class="col-6 col-md-2">
                            <label class="form-label">Resolution Status</label>
                            <select name="resolutionStatus" class="form-select">
                                <option value="All" selected="@("All" == Model.ResolutionStatus ? "selected" : null)">All Statuses</option>
                                <option value="Resolved" selected="@("Resolved" == Model.ResolutionStatus ? "selected" : null)">Resolved</option>
                                <option value="Unresolved" selected="@("Unresolved" == Model.ResolutionStatus ? "selected" : null)">Unresolved</option>
                            </select>
                        </div>
                        <div class="col-6 col-md-2">
                            <label class="form-label">Date Range</label>
                            <select id="dateRangeSelect" name="dateRange" class="form-select">
                                <option value="" selected="@(string.IsNullOrEmpty(Model.DateRange) ? "selected" : null)">All Time</option>
                                <option value="Today" selected="@("Today" == Model.DateRange ? "selected" : null)">Today</option>
                                <option value="Yesterday" selected="@("Yesterday" == Model.DateRange ? "selected" : null)">Yesterday</option>
                                <option value="Last7Days" selected="@("Last7Days" == Model.DateRange ? "selected" : null)">Last 7 Days</option>
                                <option value="Last30Days" selected="@("Last30Days" == Model.DateRange ? "selected" : null)">Last 30 Days</option>
                                <option value="Custom" selected="@("Custom" == Model.DateRange ? "selected" : null)">Custom Range</option>
                            </select>
                        </div>
                        <div class="col-6 col-md-3 d-flex align-items-end">
                            <div class="w-100 d-flex gap-2">
                                <button type="submit" class="btn btn-primary w-50">
                                    <i class="bi bi-funnel-fill"></i> Filter
                                </button>
                                <a href="/Home/ErrorLogs" class="btn btn-outline-secondary w-50">
                                    <i class="bi bi-x-lg"></i> Clear
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Custom Date Fields -->
                    <div id="customDateContainer" class="row g-3 mt-1" style="display: @("Custom" == Model.DateRange ? "row" : "none")">
                        <div class="col-6 col-md-3">
                            <label class="form-label">Start Date</label>
                            <input type="date" name="startDate" class="form-control" value="@Model.StartDate" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">End Date</label>
                            <input type="date" name="endDate" class="form-control" value="@Model.EndDate" />
                        </div>
                    </div>
                </form>
            </div>

            <!-- Export Buttons and Info -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="text-muted" style="font-size: 14px;">
                    Showing <strong>@Model.Logs.Count</strong> of <strong>@Model.TotalItems</strong> filtered records
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-success" onclick="exportData('csv')">
                        <i class="bi bi-filetype-csv"></i> Export CSV
                    </button>
                    <button class="btn btn-sm btn-success" onclick="exportData('excel')">
                        <i class="bi bi-file-earmark-excel"></i> Export Excel
                    </button>
                </div>
            </div>

            <!-- Table of Logs -->
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Severity</th>
                            <th>Exception Type</th>
                            <th>Message</th>
                            <th>Location (Ctrl / Act)</th>
                            <th>User</th>
                            <th>Count</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Logs.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">
                                    <i class="bi bi-journal-x" style="font-size: 32px; display: block; margin-bottom: 10px;"></i>
                                    No error logs found matching filters.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var log in Model.Logs)
                            {
                                string severityClass = log.Severity switch
                                {
                                    "Critical" => "severity-critical",
                                    "High" => "severity-high",
                                    "Medium" => "severity-medium",
                                    _ => "severity-low"
                                };

                                string statusClass = log.IsResolved ? "status-resolved" : "status-unresolved";
                                string statusLabel = log.IsResolved ? "Resolved" : "Unresolved";

                                <tr onclick="showLogDetails(@Json.Serialize(log))">
                                    <td class="text-nowrap" style="font-size: 13.5px;">
                                        @log.LastOccurredOn.ToString("yyyy-MM-dd HH:mm:ss")
                                    </td>
                                    <td>
                                        <span class="badge-severity @severityClass">@log.Severity</span>
                                    </td>
                                    <td class="text-truncate" style="max-width: 150px; font-size: 13.5px;" title="@log.ExceptionType">
                                        @log.ExceptionType?.Split('.').Last()
                                    </td>
                                    <td class="text-truncate" style="max-width: 300px; font-size: 13.5px;" title="@log.ExceptionMessage">
                                        @log.ExceptionMessage
                                    </td>
                                    <td style="font-size: 13.5px;">
                                        <code>@log.Controller / @log.Action</code>
                                    </td>
                                    <td style="font-size: 13.5px;">
                                        @(string.IsNullOrEmpty(log.Username) ? "Anonymous" : log.Username)
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary rounded-pill">@log.OccurrenceCount</span>
                                    </td>
                                    <td>
                                        <span class="badge-status @statusClass">@statusLabel</span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation">
                    <ul class="pagination">
                        <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                            <a class="page-link" href="#" onclick="changePage(@(Model.PageNumber - 1))">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.PageNumber == i ? "active" : "")">
                                <a class="page-link" href="#" onclick="changePage(@i)">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" href="#" onclick="changePage(@(Model.PageNumber + 1))">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }

        </div>

    </div>

    <!-- Error Details Modal -->
    <div class="modal fade" id="errorDetailsModal" tabindex="-1" aria-labelledby="errorDetailsModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="errorDetailsModalLabel">
                        <i class="bi bi-bug text-danger me-2"></i> Error Log Details
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="detail-group">
                                <div class="detail-label">Correlation ID</div>
                                <div id="modalCorrelationId" class="detail-value font-monospace"></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-group">
                                <div class="detail-label">Severity</div>
                                <div id="modalSeverity" class="d-inline-block"></div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="detail-group">
                                <div class="detail-label">First Occurred</div>
                                <div id="modalDateTime" class="detail-value"></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-group">
                                <div class="detail-label">Last Occurred</div>
                                <div id="modalLastOccurred" class="detail-value"></div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="detail-group">
                                <div class="detail-label">Occurrence Count</div>
                                <div id="modalCount" class="detail-value"></div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="detail-group">
                                <div class="detail-label">User / ID / Role</div>
                                <div id="modalUser" class="detail-value"></div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="detail-group">
                                <div class="detail-label">IP Address</div>
                                <div id="modalIpAddress" class="detail-value"></div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-3">
                            <div class="detail-group">
                                <div class="detail-label">HTTP Method</div>
                                <div id="modalMethod" class="detail-value"></div>
                            </div>
                        </div>
                        <div class="col-md-9">
                            <div class="detail-group">
                                <div class="detail-label">Request URL</div>
                                <div id="modalRequestUrl" class="detail-value"></div>
                            </div>
                        </div>
                    </div>

                    <div class="detail-group">
                        <div class="detail-label">User Agent</div>
                        <div id="modalUserAgent" class="detail-value" style="font-size: 13px;"></div>
                    </div>

                    <div class="detail-group">
                        <div class="detail-label">Exception Type</div>
                        <div id="modalExceptionType" class="detail-value text-danger font-monospace fw-bold" style="font-size: 13.5px;"></div>
                    </div>

                    <div class="detail-group">
                        <div class="detail-label">Message</div>
                        <div id="modalMessage" class="detail-value text-warning fw-bold" style="font-size: 14.5px;"></div>
                    </div>

                    <div id="innerExceptionContainer" class="detail-group" style="display:none;">
                        <div class="detail-label">Inner Exception</div>
                        <div id="modalInnerException" class="detail-value font-monospace" style="font-size: 13px;"></div>
                    </div>

                    <div class="detail-group">
                        <div class="detail-label">Stack Trace</div>
                        <pre id="modalStackTrace" class="stack-trace-box"></pre>
                    </div>

                    <!-- Resolution details if resolved -->
                    <div id="resolutionContainer" class="p-3 bg-success bg-opacity-10 border border-success rounded-3 mt-3" style="display:none;">
                        <h6 class="text-success fw-bold mb-2"><i class="bi bi-patch-check-fill"></i> Resolved Issue Details</h6>
                        <div class="row text-white-50" style="font-size: 13px;">
                            <div class="col-md-6">
                                <strong>Resolved By:</strong> <span id="modalResolvedBy" class="text-white"></span>
                            </div>
                            <div class="col-md-6">
                                <strong>Resolved On:</strong> <span id="modalResolvedOn" class="text-white"></span>
                            </div>
                        </div>
                        <div class="mt-2 text-white" style="font-size: 13.5px;">
                            <strong>Remarks:</strong> <span id="modalRemarks"></span>
                        </div>
                    </div>

                    <!-- Resolve Log Action Panel (Unresolved only) -->
                    <div id="resolveFormContainer" class="p-3 bg-primary bg-opacity-10 border border-primary border-opacity-50 rounded-3 mt-3" style="display:none;">
                        <h6 class="text-primary-emphasis fw-bold mb-3"><i class="bi bi-pencil-square"></i> Update Log Resolution</h6>
                        <form asp-action="ResolveErrorLog" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" id="modalResolveId" />
                            <div class="mb-3">
                                <label class="form-label text-white-50">Resolution Remarks</label>
                                <textarea name="remarks" class="form-control" rows="2" placeholder="e.g. Fixed database lock, query optimized, etc." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-sm btn-primary">
                                <i class="bi bi-check2"></i> Mark as Resolved
                            </button>
                        </form>
                    </div>

                </div>
                <div class="modal-footer justify-content-between">
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-info btn-action-modal" onclick="copyExceptionText()">
                            <i class="bi bi-copy"></i> Copy Exception
                        </button>
                        <button class="btn btn-sm btn-outline-secondary btn-action-modal" onclick="copyStackTraceText()">
                            <i class="bi bi-file-earmark-code"></i> Copy Stack
                        </button>
                        <button class="btn btn-sm btn-outline-primary btn-action-modal" onclick="downloadLogFile()">
                            <i class="bi bi-download"></i> Download Log
                        </button>
                    </div>
                    <div class="d-flex gap-2">
                        <!-- Only Admin/SuperAdmin can delete, SuperAdmin can do all -->
                        <form id="deleteLogForm" asp-action="DeleteErrorLog" method="post" onsubmit="return confirm('Are you sure you want to delete this log?');" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" id="modalDeleteId" />
                            <button type="submit" class="btn btn-sm btn-danger btn-action-modal">
                                <i class="bi bi-trash"></i> Delete Log
                            </button>
                        </form>
                        <button type="button" class="btn btn-sm btn-secondary btn-action-modal" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap 5 and jQuery script loading -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        var selectedLog = null;

        // Custom Date Filters display toggle
        document.getElementById('dateRangeSelect').addEventListener('change', function() {
            var val = this.value;
            var container = document.getElementById('customDateContainer');
            if (val === 'Custom') {
                container.style.display = 'flex';
            } else {
                container.style.display = 'none';
            }
        });

        // Trigger pagination page submit
        function changePage(page) {
            var form = document.getElementById('filterForm');
            
            // Remove existing pageNumber input if exists
            var existing = form.querySelector('input[name="pageNumber"]');
            if (existing) {
                existing.value = page;
            } else {
                var input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'pageNumber';
                input.value = page;
                form.appendChild(input);
            }
            form.submit();
        }

        // Export data
        function exportData(format) {
            var form = document.getElementById('filterForm');
            var formData = new FormData(form);
            var params = new URLSearchParams();
            
            for (var pair of formData.entries()) {
                if (pair[0] !== 'pageNumber') {
                    params.append(pair[0], pair[1]);
                }
            }
            params.append('format', format);
            
            window.location.href = '/Home/ExportErrorLogs?' + params.toString();
        }

        // Open details modal
        var detailsModal = new bootstrap.Modal(document.getElementById('errorDetailsModal'));

        function showLogDetails(log) {
            selectedLog = log;

            // Fill values
            document.getElementById('modalCorrelationId').innerText = log.correlationId || 'N/A';
            
            // Severity badge
            var severityDiv = document.getElementById('modalSeverity');
            var severityClass = log.severity === 'Critical' ? 'severity-critical' :
                                log.severity === 'High' ? 'severity-high' :
                                log.severity === 'Medium' ? 'severity-medium' : 'severity-low';
            severityDiv.innerHTML = `<span class="badge-severity ${severityClass}">${log.severity}</span>`;

            document.getElementById('modalDateTime').innerText = log.dateTime ? formatDateTime(log.dateTime) : 'N/A';
            document.getElementById('modalLastOccurred').innerText = log.lastOccurredOn ? formatDateTime(log.lastOccurredOn) : 'N/A';
            document.getElementById('modalCount').innerText = log.occurrenceCount || '1';
            
            var userText = (log.username || 'Anonymous') + ' (' + (log.role || 'Visitor') + ')';
            if (log.userId) userText += ` [ID: ${log.userId}]`;
            document.getElementById('modalUser').innerText = userText;

            document.getElementById('modalIpAddress').innerText = log.ipAddress || 'N/A';
            document.getElementById('modalMethod').innerText = log.httpMethod || 'N/A';
            document.getElementById('modalRequestUrl').innerText = log.requestUrl || 'N/A';
            document.getElementById('modalUserAgent').innerText = log.userAgent || 'N/A';
            document.getElementById('modalExceptionType').innerText = log.exceptionType || 'N/A';
            document.getElementById('modalMessage').innerText = log.exceptionMessage || 'N/A';

            // Inner Exception
            var innerContainer = document.getElementById('innerExceptionContainer');
            if (log.innerException) {
                innerContainer.style.display = 'block';
                document.getElementById('modalInnerException').innerText = log.innerException;
            } else {
                innerContainer.style.display = 'none';
            }

            // Stack Trace
            document.getElementById('modalStackTrace').innerText = log.stackTrace || 'No stack trace available.';

            // Resolution forms and containers
            var resContainer = document.getElementById('resolutionContainer');
            var formContainer = document.getElementById('resolveFormContainer');
            document.getElementById('modalResolveId').value = log.logId;
            document.getElementById('modalDeleteId').value = log.logId;

            if (log.isResolved) {
                resContainer.style.display = 'block';
                formContainer.style.display = 'none';
                document.getElementById('modalResolvedBy').innerText = log.resolvedBy || 'Admin';
                document.getElementById('modalResolvedOn').innerText = log.resolvedOn ? formatDateTime(log.resolvedOn) : 'N/A';
                document.getElementById('modalRemarks').innerText = log.remarks || 'No remarks provided.';
            } else {
                resContainer.style.display = 'none';
                formContainer.style.display = 'block';
            }

            // Show modal
            detailsModal.show();
        }

        function formatDateTime(dateStr) {
            var date = new Date(dateStr);
            if (isNaN(date.getTime())) return dateStr;
            return date.getFullYear() + '-' + 
                padZero(date.getMonth() + 1) + '-' + 
                padZero(date.getDate()) + ' ' + 
                padZero(date.getHours()) + ':' + 
                padZero(date.getMinutes()) + ':' + 
                padZero(date.getSeconds());
        }

        function padZero(num) {
            return num < 10 ? '0' + num : num;
        }

        // Copy actions
        function copyExceptionText() {
            if (!selectedLog) return;
            var text = (selectedLog.exceptionType || '') + ': ' + (selectedLog.exceptionMessage || '');
            copyToClipboard(text, "Exception details copied!");
        }

        function copyStackTraceText() {
            if (!selectedLog || !selectedLog.stackTrace) return;
            copyToClipboard(selectedLog.stackTrace, "Stack trace copied!");
        }

        function copyToClipboard(text, successMsg) {
            navigator.clipboard.writeText(text).then(function() {
                alert(successMsg);
            }, function(err) {
                alert('Could not copy text: ' + err);
            });
        }

        // Download Log action
        function downloadLogFile() {
            if (!selectedLog) return;
            var logContent = "ENTERPRISE ERROR LOG DETAIL\n";
            logContent += "====================================\n";
            logContent += "Log ID: " + selectedLog.logId + "\n";
            logContent += "Correlation ID: " + (selectedLog.correlationId || 'N/A') + "\n";
            logContent += "Severity: " + (selectedLog.severity || 'N/A') + "\n";
            logContent += "DateTime: " + selectedLog.dateTime + "\n";
            logContent += "Last Occurred: " + selectedLog.lastOccurredOn + "\n";
            logContent += "Occurrence Count: " + (selectedLog.occurrenceCount || '1') + "\n";
            logContent += "User: " + (selectedLog.username || 'Anonymous') + " (Role: " + (selectedLog.role || 'N/A') + ", ID: " + (selectedLog.userId || 'N/A') + ")\n";
            logContent += "IP Address: " + (selectedLog.ipAddress || 'N/A') + "\n";
            logContent += "HTTP Method: " + (selectedLog.httpMethod || 'N/A') + "\n";
            logContent += "Request URL: " + (selectedLog.requestUrl || 'N/A') + "\n";
            logContent += "User Agent: " + (selectedLog.userAgent || 'N/A') + "\n";
            logContent += "Exception Type: " + (selectedLog.exceptionType || 'N/A') + "\n";
            logContent += "Message: " + (selectedLog.exceptionMessage || 'N/A') + "\n";
            if (selectedLog.innerException) {
                logContent += "Inner Exception: " + selectedLog.innerException + "\n";
            }
            logContent += "\nSTACK TRACE:\n";
            logContent += (selectedLog.stackTrace || 'No stack trace available.') + "\n";
            
            if (selectedLog.isResolved) {
                logContent += "\nRESOLUTION DETAILS:\n";
                logContent += "Resolved By: " + (selectedLog.resolvedBy || 'Admin') + "\n";
                logContent += "Resolved On: " + selectedLog.resolvedOn + "\n";
                logContent += "Remarks: " + (selectedLog.remarks || 'None') + "\n";
            }

            var blob = new Blob([logContent], { type: "text/plain;charset=utf-8" });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = "error_log_" + selectedLog.logId + "_" + (selectedLog.correlationId || 'log') + ".txt";
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }
    </script>
</body>
</html>
