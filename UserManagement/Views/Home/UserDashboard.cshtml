@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Dashboard</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                min-height: 100vh;
                font-family: 'Segoe UI', sans-serif;
                background-image: url('/User.png');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                display: flex;
                align-items: center;
                justify-content: flex-start;
            }

            .dashboard-container {
                margin-left: 8%;
                width: 100%;
            }

            /* HEADING OUTSIDE CARD */

            .page-heading {
                color: white;
                font-size: 52px;
                font-weight: 800;
                text-transform: uppercase;
                margin-bottom: 25px;
                text-shadow: 0 4px 15px rgba(0,0,0,0.4);
            }

            /* MAIN CARD */
            
            .main-card {
                max-width: 800px;
                width: 100%;
                min-height: 430px;
                background: #ffffff;
                border-radius: 25px;
                padding: 45px 50px;
                box-shadow: 0 20px 60px rgba(0,0,0,0.35);
                display: flex;
                flex-direction: column;
                justify-content: center;
            }

            /* USER ICON */

            .user-avatar {
                width: 100px;
                height: 100px;
                border-radius: 50%;
                background: #2563eb;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 45px;
                margin-bottom: 25px;
            }

            /* WELCOME TITLE */

            .welcome-title {
                color: #0f172a;
                font-size: 40px;
                font-weight: 700;
                margin-bottom: 15px;
            }

            /* DESCRIPTION */

            .welcome-text {
                color: #0a2a66;
                font-size: 18px;
                line-height: 1.8;
                margin-bottom: 35px;
            }

            /* BUTTON */

            .btn-logout {
                background: #dc2626;
                color: white;
                text-decoration: none;
                padding: 14px 35px;
                border-radius: 12px;
                font-size: 16px;
                font-weight: 600;
                width: fit-content;
                transition: all 0.3s ease;
                border: none;
            }

            .btn-logout:hover {
                background: #b91c1c;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(220, 38, 38, 0.3);
            }

            /* DOCUMENT STATUS GRID */
            .doc-status-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
                gap: 20px;
                margin: 25px 0;
            }

            .doc-status-card {
                background: #f8fafc;
                border: 1px solid #e2e8f0;
                border-radius: 18px;
                padding: 20px;
                text-align: center;
                transition: all 0.3s ease;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: space-between;
                min-height: 200px;
            }

            .doc-status-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(0,0,0,0.06);
                border-color: #cbd5e1;
            }

            .doc-icon {
                font-size: 32px;
                margin-bottom: 8px;
            }

            .doc-title {
                font-size: 15px;
                font-weight: 700;
                color: #1e293b;
                margin-bottom: 6px;
            }

            .doc-req {
                font-size: 10px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                padding: 3px 10px;
                border-radius: 20px;
                margin-bottom: 12px;
            }

            .req-mandatory {
                background: #fef2f2;
                color: #ef4444;
            }

            .req-optional {
                background: #f1f5f9;
                color: #64748b;
            }

            .btn-action-container {
                display: flex;
                flex-direction: column;
                gap: 12px;
                margin: 20px 0 35px 0;
            }

            /* MOBILE */

            @@media(max-width:768px) {

                .dashboard-container {
                    margin: 20px;
                }

                .page-heading {
                    font-size: 32px;
                }

                .main-card {
                    width: 100%;
                    min-height: auto;
                    padding: 35px;
                }

                .welcome-title {
                    font-size: 28px;
                }
            }

    </style>
</head>
<body>

    <div class="dashboard-container">

        <!-- HEADING OUTSIDE THE CARD -->
        <h1 class="page-heading">
            USER DASHBOARD
        </h1>

        <!-- CARD -->
        <div class="main-card">

            <div class="user-avatar">
                👤
            </div>

            <h2 class="welcome-title">
                Welcome Back, @ViewBag.Username!
            </h2>

            <p class="welcome-text">
                You have successfully logged into your secure profile.
                Manage your account and continue your work securely.
            </p>
            <div class="mt-3 mb-4">

                @if (ViewBag.DocumentStatus == "Approved")
                {
                    <div class="alert alert-success fw-bold">
                        ✅ Documents Verified Successfully
                    </div>
                }
                else if (ViewBag.DocumentStatus == "Rejected")
                {
                    <div class="alert alert-danger fw-bold">
                        ❌ Documents Rejected By Admin
                    </div>
                }
                else if (ViewBag.DocumentStatus == "Pending")
                {
                    <div class="alert alert-warning fw-bold">
                        ⏳ Documents Under Verification
                    </div>
                }

            </div>

            <hr />

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            @if (ViewBag.HasMandatory == false)
            {
                <div class="alert alert-warning border-0 p-3 mb-4 d-flex align-items-center gap-2.5" style="border-radius: 12px; background-color: #fffbeb; color: #b45309; font-size: 14px; font-weight: 600;">
                    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    <div>Aadhaar Card and PAN Card are mandatory. Please upload them to complete your verification.</div>
                </div>
            }
            else
            {
                <div class="alert alert-success border-0 p-3 mb-4 d-flex align-items-center gap-2.5" style="border-radius: 12px; background-color: #f0fdf4; color: #15803d; font-size: 14px; font-weight: 600;">
                    <i class="bi bi-check-circle-fill fs-5"></i>
                    <div>All mandatory documents uploaded successfully. Under verification.</div>
                </div>
            }

            <h3 class="mt-2 mb-3" style="font-size: 20px; font-weight: 700; color: #1e293b;">
                📁 Document Verification Status
            </h3>

            <div class="doc-status-grid">
                <!-- Aadhaar Card Card -->
                <div class="doc-status-card">
                    <div class="d-flex flex-column align-items-center">
                        <span class="doc-icon">🪪</span>
                        <h4 class="doc-title">Aadhaar Card <span class="text-danger">*</span></h4>
                    </div>
                    
                    <div class="w-100">
                        @if (ViewBag.AadhaarStatus == "Approved")
                        {
                            <span class="badge bg-success py-2 w-100" style="border-radius: 8px;"><i class="bi bi-check-circle-fill"></i> Approved</span>
                        }
                        else if (ViewBag.AadhaarStatus == "Rejected")
                        {
                            <span class="badge bg-danger py-2 w-100" style="border-radius: 8px;"><i class="bi bi-x-circle-fill"></i> Rejected</span>
                        }
                        else if (ViewBag.AadhaarStatus == "Pending")
                        {
                            <span class="badge bg-warning text-dark py-2 w-100" style="border-radius: 8px;"><i class="bi bi-hourglass-split"></i> Pending</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary py-2 w-100" style="border-radius: 8px;"><i class="bi bi-file-earmark-x"></i> Missing</span>
                        }
                    </div>
                </div>

                <!-- PAN Card Card -->
                <div class="doc-status-card">
                    <div class="d-flex flex-column align-items-center">
                        <span class="doc-icon">💳</span>
                        <h4 class="doc-title">PAN Card <span class="text-danger">*</span></h4>
                    </div>
                    
                    <div class="w-100">
                        @if (ViewBag.PanStatus == "Approved")
                        {
                            <span class="badge bg-success py-2 w-100" style="border-radius: 8px;"><i class="bi bi-check-circle-fill"></i> Approved</span>
                        }
                        else if (ViewBag.PanStatus == "Rejected")
                        {
                            <span class="badge bg-danger py-2 w-100" style="border-radius: 8px;"><i class="bi bi-x-circle-fill"></i> Rejected</span>
                        }
                        else if (ViewBag.PanStatus == "Pending")
                        {
                            <span class="badge bg-warning text-dark py-2 w-100" style="border-radius: 8px;"><i class="bi bi-hourglass-split"></i> Pending</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary py-2 w-100" style="border-radius: 8px;"><i class="bi bi-file-earmark-x"></i> Missing</span>
                        }
                    </div>
                </div>

                <!-- Other Document Card -->
                <div class="doc-status-card">
                    <div class="d-flex flex-column align-items-center">
                        <span class="doc-icon">📄</span>
                        <h4 class="doc-title">Other Document</h4>
                    </div>
                    
                    <div class="w-100">
                        @if (ViewBag.OtherStatus == "Approved")
                        {
                            <span class="badge bg-success py-2 w-100" style="border-radius: 8px;"><i class="bi bi-check-circle-fill"></i> Approved</span>
                        }
                        else if (ViewBag.OtherStatus == "Rejected")
                        {
                            <span class="badge bg-danger py-2 w-100" style="border-radius: 8px;"><i class="bi bi-x-circle-fill"></i> Rejected</span>
                        }
                        else if (ViewBag.OtherStatus == "Pending")
                        {
                            <span class="badge bg-warning text-dark py-2 w-100" style="border-radius: 8px;"><i class="bi bi-hourglass-split"></i> Pending</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary py-2 w-100" style="border-radius: 8px;"><i class="bi bi-file-earmark-x"></i> Not Uploaded</span>
                        }
                    </div>
                </div>
            </div>

            <div class="btn-action-container">
                @if (ViewBag.AadhaarStatus == "Missing" || ViewBag.PanStatus == "Missing" || ViewBag.OtherStatus == "Missing")
                {
                    <a asp-controller="Home" asp-action="UploadDocuments" class="btn btn-success d-inline-flex align-items-center justify-content-center gap-2" style="height: 52px; border-radius: 12px; font-weight: 700; font-size: 16px;">
                        <i class="bi bi-cloud-arrow-up-fill"></i> Upload Documents
                    </a>
                }
                
                @if (ViewBag.HasAnyDocument == true)
                {
                    <a asp-controller="Home" asp-action="ViewDocuments" class="btn btn-primary d-inline-flex align-items-center justify-content-center gap-2" style="height: 52px; border-radius: 12px; font-weight: 700; font-size: 16px;">
                        <i class="bi bi-file-earmark-text-fill"></i> View Uploaded Documents
                    </a>
                }
            </div>

            <a asp-controller="Home"
               asp-action="Logout"
               class="btn-logout">
                Log Out
            </a>

        </div>

    </div>

</body>
</html>