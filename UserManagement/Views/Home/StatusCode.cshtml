@{
    Layout = null;
    int statusCode = ViewBag.StatusCode ?? 500;
    string message = ViewBag.Message ?? "Something went wrong.";
    string description = ViewBag.Description ?? "An unexpected error occurred.";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@statusCode - @message</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #0b132b, #1c2541);
            color: #ffffff;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            padding: 20px;
        }

        .error-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 50px 40px;
            text-align: center;
            max-width: 550px;
            width: 100%;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
            animation: fadeIn 0.8s ease-out;
        }

        .error-code {
            font-size: 110px;
            font-weight: 900;
            background: linear-gradient(135deg, #3b82f6, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            line-height: 1;
            margin-bottom: 10px;
            letter-spacing: -2px;
        }

        .error-icon {
            font-size: 60px;
            color: #60a5fa;
            margin-bottom: 20px;
            display: inline-block;
            animation: pulse 2s infinite alternate;
        }

        .error-message {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 15px;
            color: #f1f5f9;
        }

        .error-description {
            font-size: 16px;
            color: #94a3b8;
            margin-bottom: 35px;
            line-height: 1.6;
        }

        .btn-group {
            display: flex;
            gap: 15px;
            justify-content: center;
        }

        .btn-action {
            padding: 12px 28px;
            border-radius: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary-action {
            background: linear-gradient(135deg, #2563eb, #3b82f6);
            color: white;
            border: none;
        }

        .btn-primary-action:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(59, 130, 246, 0.4);
        }

        .btn-secondary-action {
            background: rgba(255, 255, 255, 0.08);
            color: #e2e8f0;
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .btn-secondary-action:hover {
            color: white;
            background: rgba(255, 255, 255, 0.15);
            transform: translateY(-2px);
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes pulse {
            from {
                transform: scale(1);
            }
            to {
                transform: scale(1.05);
            }
        }
    </style>
</head>
<body>
    <div class="error-card">
        <div class="error-icon">
            @if (statusCode == 401)
            {
                <i class="bi bi-shield-lock"></i>
            }
            else if (statusCode == 403)
            {
                <i class="bi bi-shield-slash"></i>
            }
            else if (statusCode == 404)
            {
                <i class="bi bi-search-heart"></i>
            }
            else
            {
                <i class="bi bi-exclamation-triangle"></i>
            }
        </div>
        <div class="error-code">@statusCode</div>
        <div class="error-message">@message</div>
        <div class="error-description">@description</div>
        <div class="btn-group">
            <a href="javascript:history.back()" class="btn-action btn-secondary-action">
                <i class="bi bi-arrow-left"></i> Go Back
            </a>
            <a href="/" class="btn-action btn-primary-action">
                <i class="bi bi-house-door"></i> Home
            </a>
        </div>
    </div>
</body>
</html>
