@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                min-height: 100vh;
                font-family: 'Segoe UI', sans-serif;
                background: url('/admin.png');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                overflow-x: hidden;
                position: relative;
            }

            .page-overlay-final {
                position: absolute;
                inset: 0;
                background: linear-gradient(90deg, rgba(7, 18, 40, 0.2) 0%, rgba(7, 18, 40, 0.8) 40%, rgba(7, 18, 40, 0.85) 75%, rgba(0, 0, 0, 0.3) 100%);
                z-index: 1;
            }

            .left-side-container-final {
                position: absolute !important;
                top: 50% !important;
                left: 42% !important;
                right: auto !important;
                transform: translateY(-50%) !important;
                width: 580px !important;
                z-index: 999 !important;
            }

            .header-section-final {
                text-align: left;
                padding-left: 10px;
            }

                .header-section-final h1 {
                    font-size: 56px;
                    font-weight: 900;
                    color: white;
                    margin-bottom: 4px;
                    text-shadow: 0 5px 20px rgba(0,0,0,.4);
                }

                .header-section-final span {
                    color: #3b82f6;
                }

                .header-section-final p {
                    color: #dbeafe;
                    font-size: 20px;
                    margin-left: 5px;
                    margin-bottom: 25px;
                }

            .card-box-final {
                background: rgba(255, 255, 255, 0.06);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border: 1px solid rgba(59, 130, 246, 0.3);
                border-radius: 25px;
                padding: 45px;
                box-shadow: 0 0 30px rgba(59, 130, 246, 0.15), 0 15px 40px rgba(0, 0, 0, 0.4);
                color: white;
            }

            .icon-circle-final {
                width: 80px;
                height: 80px;
                border-radius: 50%;
                display: flex;
                justify-content: center;
                align-items: center;
                background: linear-gradient(135deg, #2563eb, #3b82f6);
                color: white;
                font-size: 35px;
                margin-bottom: 20px;
            }

            .text-welcome-final {
                text-align: left;
                font-size: 36px;
                color: white;
                margin-bottom: 10px;
            }

            .text-sub-final {
                text-align: left;
                margin-bottom: 30px;
                color: #cbd5e1;
                font-size: 15px;
                line-height: 1.6;
            }

            .btn-group-final {
                display: flex;
                gap: 15px;
                flex-wrap: wrap;
            }

            .btn-blue-final {
                background: linear-gradient(135deg, #2563eb, #3b82f6);
                color: white;
                text-decoration: none;
                padding: 14px 28px;
                border-radius: 12px;
                font-size: 16px;
                font-weight: 700;
                transition: .3s;
                display: inline-flex;
                align-items: center;
                gap: 10px;
            }

                .btn-blue-final:hover {
                    color: white;
                    transform: translateY(-3px);
                    box-shadow: 0 5px 15px rgba(59, 130, 246, 0.4);
                }

            .btn-red-final {
                background: linear-gradient(135deg, #dc2626, #ef4444);
                color: white;
                text-decoration: none;
                padding: 14px 28px;
                border-radius: 12px;
                font-size: 16px;
                font-weight: 700;
                transition: .3s;
                display: inline-flex;
                align-items: center;
                gap: 10px;
            }

                .btn-red-final:hover {
                    color: white;
                    transform: translateY(-3px);
                    box-shadow: 0 5px 15px rgba(239, 68, 68, 0.4);
                }

            @@media(max-width:768px) {
                body {
                    overflow: auto;
                }

                .left-side-container-final {
                    position: static !important;
                    transform: none !important;
                    width: 100% !important;
                    padding: 20px !important;
                    margin-top: 30px !important;
                }
            }
    </style>
</head>
<body>

    <div class="page-overlay-final"></div>

    <div class="left-side-container-final">

        <div class="header-section-final">
            <h1>
                ADMIN <span>DASHBOARD</span>
            </h1>
            <p>
                User Management System
            </p>
        </div>

        <div class="card-box-final">
            <div class="icon-circle-final">
                <i class="bi bi-person"></i>
            </div>

            <h2 class="text-welcome-final">
                Welcome Back, @ViewBag.Username
            </h2>

            <p class="text-sub-final">
                Manage registered users, update user information,
                monitor activities and maintain the User Management
                System securely and efficiently.
            </p>

            <div class="btn-group-final">

                <a asp-controller="Home"
                   asp-action="UserList"
                   class="btn-blue-final">

                    <i class="bi bi-people-fill"></i>
                    View Users List

                </a>

                <a asp-controller="Home"
                   asp-action="AdminDocuments"
                   class="btn-blue-final">

                    <i class="bi bi-file-earmark-check-fill"></i>
                    Verify Documents

                </a>

                <a asp-controller="Home"
                   asp-action="ErrorLogs"
                   class="btn-blue-final">

                    <i class="bi bi-shield-exclamation"></i>
                    Error Logs

                </a>

                <a asp-controller="Home"
                   asp-action="Logout"
                   class="btn-red-final">

                    <i class="bi bi-box-arrow-right"></i>
                    Logout

                </a>

            </div>
        </div>

    </div>

</body>
</html>