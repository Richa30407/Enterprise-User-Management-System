@model List<UserManagement.Models.UserModel>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registered Users - Admin Control</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        body {
            background: linear-gradient(135deg, #0b132b, #1c2541);
            min-height: 100vh;
            padding: 40px 0;
            font-family: 'Segoe UI', sans-serif;
        }

        .container-box {
            width: 90%;
            max-width: 1100px;
            margin: 0 auto;
            background: white;
            padding: 35px;
            border-radius: 20px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #f1f5f9;
            padding-bottom: 20px;
            margin-bottom: 25px;
        }

        .page-title {
            color: #0b132b;
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* TABLE CUSTOM STYLING */
        .table {
            border-collapse: separate;
            border-spacing: 0;
        }

        .table th {
            background: #1c2541 !important;
            color: white;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 0.5px;
            padding: 16px 12px;
            text-align: center;
            vertical-align: middle;
            border: none;
        }

        .table th:first-child {
            border-top-left-radius: 10px;
        }

        .table th:last-child {
            border-top-right-radius: 10px;
        }

        .table td {
            padding: 14px 12px;
            text-align: center;
            vertical-align: middle;
            color: #334155;
            font-size: 14.5px;
            border-bottom: 1px solid #e2e8f0;
        }

        .table tbody tr {
            transition: all 0.2s ease;
        }

        .table tbody tr:hover {
            background-color: #f8fafc;
        }

        /* BUTTONS HOVER EFFECTS */
        .btn-action {
            width: 38px;
            height: 38px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
            border: none;
        }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
        }

        .btn-action-view {
            background-color: #2563eb;
            color: white;
        }
        .btn-action-view:hover {
            background-color: #1d4ed8;
            color: white;
        }

        .btn-action-edit {
            background-color: #eab308;
            color: white;
        }
        .btn-action-edit:hover {
            background-color: #ca8a04;
            color: white;
        }

        .btn-action-delete {
            background-color: #ef4444;
            color: white;
        }
        .btn-action-delete:hover {
            background-color: #dc2626;
            color: white;
        }

        @@media (max-width: 768px) {
            .container-box {
                width: 95%;
                padding: 20px;
            }
            .page-title {
                font-size: 22px;
            }
            .page-header {
                flex-direction: column;
                gap: 15px;
                align-items: flex-start;
            }
        }
    </style>
</head>
<body>

    <div class="container-box">

        <!-- HEADER -->
        <div class="page-header">
            <h2 class="page-title">
                <i class="bi bi-people-fill text-primary"></i> Registered Users
            </h2>
            <a asp-action="Dashboard" class="btn btn-secondary px-4 py-2 fw-semibold" style="border-radius: 10px; font-size:14.5px;">
                <i class="bi bi-arrow-left"></i> Back To Dashboard
            </a>
        </div>

        <!-- NOTIFICATION ALERTS -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm d-flex align-items-center gap-2 mb-4" role="alert" style="border-radius: 12px; font-size: 14.5px;">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <div>@TempData["Success"]</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm d-flex align-items-center gap-2 mb-4" role="alert" style="border-radius: 12px; font-size: 14.5px;">
                <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                <div>@TempData["Error"]</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- USERS TABLE -->
        <div class="table-responsive" style="border-radius: 10px; border: 1px solid #e2e8f0; overflow: hidden;">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th>Email ID</th>
                        <th>Mobile Number</th>
                        <th>Role</th>
                        <th width="180">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td class="fw-semibold text-start ps-4">@user.FullName</td>
                                <td>@user.Username</td>
                                <td>@user.EmailId</td>
                                <td>@user.MobileNo</td>
                                <td>
                                    @if (string.Equals(user.RoleName, "Admin", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2.5 py-1.5 d-inline-flex align-items-center gap-1" style="border-radius: 6px; font-size: 12.5px; min-width: 85px; justify-content: center;">
                                            <i class="bi bi-shield-lock-fill"></i> Admin
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2.5 py-1.5 d-inline-flex align-items-center gap-1" style="border-radius: 6px; font-size: 12.5px; min-width: 85px; justify-content: center;">
                                            <i class="bi bi-person-fill"></i> User
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex justify-content-center gap-2">
                                        <!-- VIEW USER DETAILS -->
                                        <a asp-action="UserDetails"
                                           asp-route-id="@user.UserId"
                                           class="btn-action btn-action-view"
                                           data-bs-toggle="tooltip"
                                           data-bs-placement="top"
                                           title="View User Details">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>

                                        <!-- EDIT USER -->
                                        <a asp-action="EditUser"
                                           asp-route-id="@user.UserId"
                                           class="btn-action btn-action-edit"
                                           data-bs-toggle="tooltip"
                                           data-bs-placement="top"
                                           title="Edit User Info">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>

                                        <!-- DELETE USER -->
                                        <button type="button"
                                                class="btn-action btn-action-delete"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-userid="@user.UserId"
                                                data-fullname="@user.FullName"
                                                data-bs-toggle="tooltip"
                                                data-bs-placement="top"
                                                title="Delete User Account">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-secondary">
                                <i class="bi bi-people-fill text-muted fs-2 d-block mb-2"></i>
                                No registered users found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

    <!-- DELETE CONFIRMATION MODAL -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 18px; border: none; box-shadow: 0 15px 35px rgba(0,0,0,0.35);">
                <div class="modal-header bg-danger text-white border-0 py-3 px-4" style="border-top-left-radius: 18px; border-top-right-radius: 18px;">
                    <h5 class="modal-title fw-bold" id="deleteModalLabel">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Account Deletion
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body px-4 py-3 text-secondary" style="font-size: 15px; line-height: 1.6;">
                    <p class="text-dark fw-bold">Are you sure you want to permanently delete this user account?</p>
                    <p class="mb-0">
                        This action will erase the account of <strong id="deleteUserFullName">the user</strong> and purge all uploaded documents. This cannot be undone.
                    </p>
                </div>
                <div class="modal-footer border-0 px-4 pb-4 pt-2 gap-2">
                    <button type="button" class="btn btn-light px-3 py-2 fw-semibold" data-bs-dismiss="modal" style="border-radius: 10px; font-size: 14px;">Cancel</button>
                    <a id="confirmDeleteBtn" href="#" class="btn btn-danger px-4 py-2 fw-semibold" style="border-radius: 10px; font-size: 14px;">
                        Delete Permanently
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Script to manage dynamic delete URL and initialize tooltips -->
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Initialize Tooltips
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function(tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });

            // Dynamic Modal Population for Deletion
            const deleteModal = document.getElementById('deleteModal');
            deleteModal.addEventListener('show.bs.modal', function(event) {
                const button = event.relatedTarget;
                const userId = button.getAttribute('data-userid');
                const fullName = button.getAttribute('data-fullname');
                
                document.getElementById("confirmDeleteBtn").href = "/Home/DeleteUser/" + userId;
                document.getElementById("deleteUserFullName").textContent = fullName;
            });
        });
    </script>

</body>
</html>