@model UserManagement.Models.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - UserManagement</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <style>
            body {
                background-color: #f4f7f6;
                font-family: 'Segoe UI', sans-serif;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .login-card {
                background: #ffffff;
                border-radius: 12px;
                box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
                width: 100%;
                max-width: 400px;
                padding: 2.5rem 2rem;
            }

            .brand-title {
                color: #1a365d;
                font-weight: 700;
                margin-bottom: 1.5rem;
                text-align: center;
            }

            .btn-primary {
                background-color: #2b6cb0;
                border: none;
                padding: 0.6rem;
                font-weight: 600;
                border-radius: 6px;
            }

                .btn-primary:hover {
                    background-color: #1a365d;
                }
    </style>
</head>
<body>

    <div class="login-card">
        <h3 class="brand-title">Account Login</h3>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success p-2 small text-center shadow-sm">
                @TempData["SuccessMessage"]
            </div>
        }

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Username" class="form-label text-secondary fw-semibold">Username</label>
                <input asp-for="Username" class="form-control" placeholder="Enter username" autocomplete="off" />
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label text-secondary fw-semibold">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
            </div>

            <button type="submit" class="btn btn-primary w-100 shadow-sm mb-3">Sign In</button>

            <div class="text-center">
                <span class="text-muted small">New here?</span>
                <a asp-action="Register" class="small text-decoration-none fw-semibold" style="color: #2b6cb0;">Create an account</a>
            </div>
        </form>
    </div>

</body>
</html>