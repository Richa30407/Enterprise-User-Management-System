@model UserManagement.Models.ResetPasswordModel

@{
    Layout = null;
    var isSuccess = TempData["ResetSuccess"] as bool? ?? false;
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Reset Password - User Management Portal</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" 
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                min-height: 100vh;
                font-family: 'Segoe UI', sans-serif;
                display: flex;
                align-items: center;
                justify-content: flex-start;
                padding-left: 12%;
                overflow-x: hidden;
                position: relative;
            }

            .animated-bg-wrapper {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                z-index: -2;
            }

            .animated-bg-image {
                width: 100%;
                height: 100%;
                background-image: url('/loginbg.png');
                background-size: cover;
                background-position: center;
                animation: bgmove 18s infinite ease-in-out;
            }

            .animated-bg-overlay {
                position: absolute;
                inset: 0;
                background: rgba(0,0,0,0.35);
            }

            @@keyframes bgmove {

                0% {
                    transform: scale(1);
                }

                50% {
                    transform: scale(1.05);
                }

                100% {
                    transform: scale(1);
                }
            }

            .login-card {
                width: 500px;
                background: rgba(255,255,255,.96);
                backdrop-filter: blur(10px);
                border-radius: 24px;
                padding: 45px;
                box-shadow: 0 25px 60px rgba(0,0,0,.25);
                border: 1px solid rgba(255,255,255,0.25);
                animation: popupForm 0.9s ease;
            }

            @@keyframes popupForm {
                0% {
                    opacity: 0;
                    transform: scale(0.9) translateY(30px);
                }
                100% {
                    opacity: 1;
                    transform: scale(1) translateY(0);
                }
            }

            .brand-title {
                text-align: center;
                font-size: 32px;
                font-weight: 800;
                color: #1E3A8A;
                margin-bottom: 10px;
            }

            .sub-title {
                text-align: center;
                font-size: 14px;
                color: #64748B;
                margin-bottom: 25px;
                line-height: 1.5;
            }

            .form-label {
                font-size: 13px;
                font-weight: 700;
                color: #475569;
                margin-bottom: 8px;
                text-transform: uppercase;
            }

            .form-control {
                height: 52px;
                border-radius: 12px;
                border: 1px solid #CBD5E1;
                font-size: 15px;
                transition: 0.3s;
            }

            .form-control:focus {
                border-color: #2563EB;
                box-shadow: 0 0 0 4px rgba(37,99,235,.15);
            }

            .input-group-text {
                border-radius: 12px 0 0 12px;
                background: #F8FAFC;
                border: 1px solid #CBD5E1;
                color: #64748B;
                padding: 0 16px;
            }

            .input-group .form-control {
                border-radius: 0;
                border-right: none;
            }

            .input-group .btn-toggle {
                border-radius: 0 12px 12px 0;
                border: 1px solid #CBD5E1;
                border-left: none;
                background: #fff;
                color: #64748B;
                transition: 0.3s;
                padding: 0 16px;
            }

            .input-group .btn-toggle:hover {
                background: #F8FAFC;
                color: #1E293B;
            }

            .btn-primary {
                height: 54px;
                border: none;
                border-radius: 12px;
                font-weight: 700;
                font-size: 16px;
                background: linear-gradient(135deg,#1E3A8A,#2563EB);
                transition: 0.3s;
            }

            .btn-primary:hover {
                background: linear-gradient(135deg,#1D4ED8,#2563EB);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(37,99,235,.3);
            }

            .btn-outline-secondary {
                height: 54px;
                border-radius: 12px;
                font-weight: 700;
                font-size: 16px;
                border: 2px solid #CBD5E1;
                color: #475569;
                background: transparent;
                transition: 0.3s;
            }

            .btn-outline-secondary:hover {
                background: #F1F5F9;
                color: #1E293B;
                border-color: #94A3B8;
            }

            /* Password Strength Styling */
            .strength-meter {
                height: 6px;
                border-radius: 3px;
                background-color: #E2E8F0;
                margin-top: 10px;
                margin-bottom: 10px;
                overflow: hidden;
                position: relative;
            }

            .strength-meter-bar {
                height: 100%;
                width: 0%;
                transition: width 0.4s ease, background-color 0.4s ease;
            }

            .strength-text {
                font-size: 12px;
                font-weight: 700;
                text-transform: uppercase;
                margin-top: 5px;
            }

            .criteria-list {
                list-style: none;
                padding-left: 0;
                margin-top: 15px;
                margin-bottom: 20px;
            }

            .criteria-item {
                font-size: 13px;
                color: #64748B;
                margin-bottom: 6px;
                display: flex;
                align-items: center;
                gap: 8px;
                transition: 0.3s;
            }

            .criteria-item.met {
                color: #16A34A;
                font-weight: 600;
            }

            .criteria-item.met i {
                color: #16A34A;
            }

            .criteria-item i {
                font-size: 14px;
                color: #94A3B8;
            }

            /* Success Flow Styling */
            .success-container {
                text-align: center;
                animation: popupForm 0.7s ease;
            }

            .success-icon-circle {
                width: 72px;
                height: 72px;
                background: #DCFCE7;
                color: #15803D;
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 36px;
                margin-bottom: 20px;
                box-shadow: 0 10px 20px rgba(22,163,74,0.15);
            }

            .countdown-badge {
                display: inline-block;
                background: #EFF6FF;
                color: #1D4ED8;
                padding: 6px 16px;
                border-radius: 30px;
                font-weight: 700;
                font-size: 13px;
                margin-top: 15px;
                margin-bottom: 25px;
                border: 1px solid #DBEAFE;
            }

            /* Responsive media queries */
            @@media(max-width:768px) {
                body {
                    padding-left: 0;
                    justify-content: center;
                    overflow-y: auto;
                }

                .login-card {
                    width: 90%;
                    max-width: 460px;
                    padding: 35px 25px;
                }

                .brand-title {
                    font-size: 26px;
                }
            }

    </style>

</head>

<body>

    <div class="animated-bg-wrapper">
        <div class="animated-bg-image"></div>
        <div class="animated-bg-overlay"></div>
    </div>

    <div class="login-card">

        @if (!string.IsNullOrEmpty(ViewBag.TokenError))
        {
            <div class="text-center">
                <div class="mb-4" style="font-size: 60px; background: #FEE2E2; color: #EF4444; width: 80px; height: 80px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; box-shadow: 0 10px 20px rgba(239,68,68,0.15); margin: 0 auto 20px auto;">
                    <i class="bi bi-x-circle-fill" style="font-size: 44px;"></i>
                </div>
                <h2 class="brand-title" style="font-size: 24px; color: #EF4444; margin-bottom: 15px;">
                    Link Invalid or Expired
                </h2>
                <p class="text-secondary mb-4" style="font-size: 14px; line-height: 1.6;">
                    @ViewBag.TokenError
                </p>
                <a asp-action="ForgotPassword" class="btn btn-primary w-100">
                    Request New Link
                </a>
            </div>
        }
        else if (isSuccess)
        {
            <div class="success-container">
                <div class="success-icon-circle">
                    <i class="bi bi-check-lg"></i>
                </div>
                <h2 class="brand-title" style="font-size: 26px; color: #15803D;">
                    Password Reset!
                </h2>
                <p class="text-secondary" style="font-size: 15px; line-height: 1.6;">
                    Your password has been successfully reset.<br>
                    You can now use your new password to sign in.
                </p>
                <div class="countdown-badge">
                    Redirecting to Login in <span id="countdown">5</span> seconds...
                </div>
                
                <a asp-action="Login" class="btn btn-primary w-100">
                    Go to Login
                </a>
            </div>
        }
        else
        {
            <h2 class="brand-title" style="font-size: 28px;">
                Reset Password
            </h2>
            <p class="sub-title">
                Set a strong password for account <strong>@ViewBag.Username</strong>.
            </p>

            <form asp-action="ResetPassword" asp-route-email="@Context.Request.Query["email"]" method="post" id="resetPasswordForm">
                
                @* CSRF Token protection *@
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Token" />

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger p-3 mb-4" style="border-radius: 12px; font-size: 14px;">
                </div>

                <!-- NEW PASSWORD -->
                <div class="mb-3">
                    <label class="form-label">
                        New Password
                    </label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-lock-fill"></i>
                        </span>
                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               id="newPassword"
                               placeholder="Enter New Password" 
                               autocomplete="new-password" />
                        <button class="btn btn-toggle" type="button" id="toggleNewPassword" title="Toggle Password Visibility">
                            <i class="bi bi-eye-fill"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password"
                          class="text-danger small mt-1 d-block fw-semibold"></span>

                    <!-- Strength Meter -->
                    <div class="strength-meter">
                        <div class="strength-meter-bar" id="strengthBar"></div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-secondary small">Password Strength:</span>
                        <span class="strength-text text-danger" id="strengthText">Weak</span>
                    </div>

                    <!-- Criteria Checklist -->
                    <ul class="criteria-list">
                        <li class="criteria-item" id="crit-length">
                            <i class="bi bi-circle"></i> At least 8 characters
                        </li>
                        <li class="criteria-item" id="crit-upper">
                            <i class="bi bi-circle"></i> One uppercase letter (A-Z)
                        </li>
                        <li class="criteria-item" id="crit-lower">
                            <i class="bi bi-circle"></i> One lowercase letter (a-z)
                        </li>
                        <li class="criteria-item" id="crit-number">
                            <i class="bi bi-circle"></i> One number (0-9)
                        </li>
                        <li class="criteria-item" id="crit-special">
                            <i class="bi bi-circle"></i> One special character (e.g. !@@#$%^&*)
                        </li>
                    </ul>
                </div>

                <!-- CONFIRM PASSWORD -->
                <div class="mb-4">
                    <label class="form-label">
                        Confirm Password
                    </label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-lock-fill"></i>
                        </span>
                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-control"
                               id="confirmPassword"
                               placeholder="Confirm New Password" 
                               autocomplete="new-password" />
                        <button class="btn btn-toggle" type="button" id="toggleConfirmPassword" title="Toggle Password Visibility">
                            <i class="bi bi-eye-fill"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword"
                          class="text-danger small mt-1 d-block fw-semibold"></span>
                </div>

                <button type="submit"
                        class="btn btn-primary w-100 mb-3">
                    Reset Password
                </button>

                <a asp-action="Login"
                   class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2">
                    Cancel
                </a>

            </form>
        }

    </div>

    <!-- Scripts -->
    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <script src="/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

    @if (isSuccess)
    {
        <script>
            var seconds = 5;
            var countdownElement = document.getElementById("countdown");
            var interval = setInterval(function () {
                seconds--;
                if (countdownElement) {
                    countdownElement.innerText = seconds;
                }
                if (seconds <= 0) {
                    clearInterval(interval);
                    window.location.href = '@Url.Action("Login", "Account")';
                }
            }, 1000);
        </script>
    }
    else if (string.IsNullOrEmpty(ViewBag.TokenError))
    {
        <script>
            // Eye toggle for new password
            document.getElementById('toggleNewPassword').addEventListener('click', function () {
                var passwordInput = document.getElementById('newPassword');
                var icon = this.querySelector('i');
                if (passwordInput.type === 'password') {
                    passwordInput.type = 'text';
                    icon.classList.replace('bi-eye-fill', 'bi-eye-slash-fill');
                } else {
                    passwordInput.type = 'password';
                    icon.classList.replace('bi-eye-slash-fill', 'bi-eye-fill');
                }
            });

            // Eye toggle for confirm password
            document.getElementById('toggleConfirmPassword').addEventListener('click', function () {
                var passwordInput = document.getElementById('confirmPassword');
                var icon = this.querySelector('i');
                if (passwordInput.type === 'password') {
                    passwordInput.type = 'text';
                    icon.classList.replace('bi-eye-fill', 'bi-eye-slash-fill');
                } else {
                    passwordInput.type = 'password';
                    icon.classList.replace('bi-eye-slash-fill', 'bi-eye-fill');
                }
            });

            // Password strength checker logic
            var newPasswordInput = document.getElementById('newPassword');
            
            function updateStrength() {
                var val = newPasswordInput.value;
                var metCount = 0;

                // Criteria validations
                var rules = {
                    length: val.length >= 8,
                    upper: /[A-Z]/.test(val),
                    lower: /[a-z]/.test(val),
                    number: /[0-9]/.test(val),
                    special: /[^A-Za-z0-9]/.test(val)
                };

                // Update criteria checks on screen
                function updateRuleVisual(id, isMet) {
                    var el = document.getElementById(id);
                    var icon = el.querySelector('i');
                    if (isMet) {
                        el.classList.add('met');
                        icon.className = 'bi bi-check-circle-fill';
                        metCount++;
                    } else {
                        el.classList.remove('met');
                        icon.className = 'bi bi-circle';
                    }
                }

                updateRuleVisual('crit-length', rules.length);
                updateRuleVisual('crit-upper', rules.upper);
                updateRuleVisual('crit-lower', rules.lower);
                updateRuleVisual('crit-number', rules.number);
                updateRuleVisual('crit-special', rules.special);

                // Update Progress Bar & Label
                var bar = document.getElementById('strengthBar');
                var text = document.getElementById('strengthText');

                if (val.length === 0) {
                    bar.style.width = '0%';
                    bar.style.backgroundColor = '#E2E8F0';
                    text.innerText = 'Weak';
                    text.className = 'strength-text text-danger';
                } else if (metCount < 3) {
                    bar.style.width = '33%';
                    bar.style.backgroundColor = '#EF4444'; // Red
                    text.innerText = 'Weak';
                    text.className = 'strength-text text-danger';
                } else if (metCount < 5) {
                    bar.style.width = '66%';
                    bar.style.backgroundColor = '#F59E0B'; // Orange/Yellow
                    text.innerText = 'Medium';
                    text.className = 'strength-text text-warning';
                } else {
                    bar.style.width = '100%';
                    bar.style.backgroundColor = '#10B981'; // Green
                    text.innerText = 'Strong';
                    text.className = 'strength-text text-success';
                }
            }

            newPasswordInput.addEventListener('input', updateStrength);
            updateStrength(); // Initial state
        </script>
    }

</body>

</html>
