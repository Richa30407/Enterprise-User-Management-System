@{
    Layout = null;
    var registeredName = TempData.Peek("RegisteredName") as string ?? "Valued Member";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registration Successful - User Management</title>
    
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" 
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* BACKGROUND */
        .animated-bg-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: -2;
        }

        .animated-bg-image {
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: url('/bg.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            animation: premiumMove 20s ease-in-out infinite;
        }

        .animated-bg-overlay {
            position: absolute;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.50);
        }

        @@keyframes premiumMove {
            0% { transform: scale(1) translateX(0px); }
            25% { transform: scale(1.03) translateX(-10px); }
            50% { transform: scale(1.05) translateY(-10px); }
            75% { transform: scale(1.03) translateX(10px); }
            100% { transform: scale(1) translateX(0px); }
        }

        /* SUCCESS CARD */
        .success-card {
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(10px);
            border-radius: 24px;
            width: 90%;
            max-width: 550px;
            padding: 45px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.35), 0 10px 25px rgba(0,0,0,0.15);
            border: 1px solid rgba(255,255,255,0.25);
            animation: popupForm 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            text-align: center;
        }

        @@keyframes popupForm {
            0% {
                opacity: 0;
                transform: scale(0.9) translateY(30px);
            }
            100% {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        /* PULSING SUCCESS ICON */
        .success-icon-wrapper {
            width: 90px;
            height: 90px;
            background: rgba(25, 135, 84, 0.1);
            border: 3px solid #198754;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px auto;
            position: relative;
            animation: pulse 2s infinite;
        }

        .success-icon-wrapper i {
            font-size: 45px;
            color: #198754;
        }

        @@keyframes pulse {
            0% {
                box-shadow: 0 0 0 0 rgba(25, 135, 84, 0.4);
            }
            70% {
                box-shadow: 0 0 0 20px rgba(25, 135, 84, 0);
            }
            100% {
                box-shadow: 0 0 0 0 rgba(25, 135, 84, 0);
            }
        }

        /* TYPOGRAPHY */
        .brand-logo-text {
            font-size: 14px;
            font-weight: 800;
            color: #1E3A8A;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 10px;
        }

        .success-title {
            font-size: 28px;
            font-weight: 800;
            color: #1E3A8A;
            margin-bottom: 8px;
        }

        .welcome-msg {
            font-size: 18px;
            font-weight: 600;
            color: #334155;
            margin-bottom: 20px;
        }

        .success-desc {
            font-size: 15px;
            color: #64748B;
            line-height: 1.6;
            margin-bottom: 30px;
        }

        /* NEXT STEPS TIMELINE */
        .steps-container {
            background: #F8FAFC;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 30px;
            text-align: left;
            border: 1px solid #E2E8F0;
        }

        .step-item {
            display: flex;
            align-items: flex-start;
            gap: 15px;
            margin-bottom: 15px;
        }

        .step-item:last-child {
            margin-bottom: 0;
        }

        .step-number {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: #2563EB;
            color: white;
            font-size: 13px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .step-number.completed {
            background: #198754;
        }

        .step-text h4 {
            font-size: 14px;
            font-weight: 700;
            color: #1E293B;
            margin-bottom: 2px;
        }

        .step-text p {
            font-size: 13px;
            color: #64748B;
            margin: 0;
        }

        /* LOGIN BUTTON */
        .btn-login {
            height: 52px;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 700;
            background: linear-gradient(135deg, #1E3A8A, #2563EB);
            color: white;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            text-decoration: none;
            box-shadow: 0 4px 6px -1px rgba(37,99,235,0.1), 0 2px 4px -1px rgba(37,99,235,0.06);
        }

        .btn-login:hover {
            transform: translateY(-2px);
            background: linear-gradient(135deg, #1D4ED8, #2563EB);
            box-shadow: 0 10px 20px rgba(37, 99, 235, 0.25);
            color: white;
        }

        /* RESPONSIVE */
        @@media(max-width: 576px) {
            body {
                overflow-y: auto;
                padding: 20px 0;
            }
            .success-card {
                padding: 30px 20px;
                border-radius: 20px;
            }
            .success-title {
                font-size: 24px;
            }
            .welcome-msg {
                font-size: 16px;
            }
        }
    </style>
</head>
<body>

    <!-- BACKGROUND -->
    <div class="animated-bg-wrapper">
        <div class="animated-bg-image"></div>
        <div class="animated-bg-overlay"></div>
    </div>

    <!-- SUCCESS CARD -->
    <div class="success-card">
        <div class="brand-logo-text">User Portal</div>
        
        <div class="success-icon-wrapper">
            <i class="bi bi-check-lg"></i>
        </div>

        <h1 class="success-title">Registration Successful!</h1>
        <h2 class="welcome-msg">Welcome, @registeredName</h2>

        <p class="success-desc">
            Your corporate account has been created successfully. You can now follow the steps below to access your secure User Management Portal.
        </p>

        <!-- NEXT STEPS TIMELINE -->
        <div class="steps-container">
            <div class="step-item">
                <div class="step-number completed"><i class="bi bi-check"></i></div>
                <div class="step-text">
                    <h4>Account Provisioned</h4>
                    <p>Your secure credentials have been saved and role assigned.</p>
                </div>
            </div>
            <div class="step-item">
                <div class="step-number">2</div>
                <div class="step-text">
                    <h4>Portal Login</h4>
                    <p>Access the system by entering your registered username & password.</p>
                </div>
            </div>
            <div class="step-item">
                <div class="step-number">3</div>
                <div class="step-text">
                    <h4>Identity Verification</h4>
                    <p>Upload your Aadhaar and PAN documents on your dashboard for verification.</p>
                </div>
            </div>
        </div>

        <!-- GO TO LOGIN BUTTON -->
        <a href="/Account/Login" class="btn-login w-100">
            <i class="bi bi-box-arrow-in-right"></i> Go To Login
        </a>
    </div>

</body>
</html>
